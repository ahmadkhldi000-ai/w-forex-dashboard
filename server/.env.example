# W Forex Server — إعدادات البيئة
# انسخ هذا الملف إلى .env وعدّل القيم حسب الحاجة

# ==========================
# إعدادات السيرفر الأساسية
# ==========================
PORT=3000
AUTH_TOKEN=WFOREX_SECRET_2026

# ==========================
# وضع المحاكاة (SIM MODE)
# ==========================
# on=عرض بيانات تجريبية حقيقية (ذهب من Yahoo + صفقات محاكاة)
# off=بانتظار بيانات البوت الحقيقي من MT5
SIM_MODE=on

# ==========================
# تيليجرام (قناة W Forex VIP)
# ==========================
TELEGRAM_TOKEN=7970131592:AAFqpL8t7Nj1IbeKR1_vZiaW1wB66jpJx6g
TELEGRAM_CHAT=-1004394697587

# ==========================
# المستخدم المالك (للإدارة)
# ==========================
OWNER_EMAIL=ahmadkhldi000@gmail.com
OWNER_NAME=Ahmad Khaldi

# ==========================
# الجلسات (Session Secret)
# ==========================
# أي نص عشوائي طويل — إذا ترك فارغاً سيُنشأ تلقائياً
SESSION_SECRET=

# ==========================
# Google OAuth (اختياري)
# ==========================
# للحصول على: https://console.cloud.google.com/apis/credentials
# أنشئ OAuth 2.0 Client ID (Web application)
# Authorized redirect URI: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==========================
# إعدادات النشر (Render)
# ==========================
# عند النشر على Render، هذه المتغيرات ستُستبدل
# بالقيم المحددة في Render Dashboard