# Google OAuth credentials — get them from https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (type: Web application)
# Authorized redirect URI: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session secret — any long random string (auto-generated if left empty)
SESSION_SECRET=

# SMTP credentials for sending password-reset emails (optional).
# Without these, reset links are printed to the server console (dev mode).
# Works with Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587,
# SMTP_USER=your@gmail.com, SMTP_PASS=your-app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
