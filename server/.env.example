# W Forex Server — إعدادات البيئة
# انسخ هذا الملف إلى .env وعدّل القيم حسب الحاجة

# ==========================
# إعدادات السيرفر الأساسية
# ==========================
PORT=3000
AUTH_TOKEN=WFOREX_SECRET_2026

# ==========================
# وضع المحاكاة (SIM MODE)
# ==========================
# on=عرض بيانات تجريبية حقيقية (ذهب من Yahoo + صفقات محاكاة)
# off=بانتظار بيانات البوت الحقيقي من MT5
SIM_MODE=on

# ==========================
# Telegram (W Forex VIP channel)
# ==========================
TELEGRAM_TOKEN=7970131592:AAFqpL8t7Nj1IbeKR1_vZiaW1wB66jpJx6g
TELEGRAM_CHAT=-1004394697587
# Direct invite link to the private Telegram channel (shown in the dashboard popup)
TELEGRAM_CHANNEL_LINK=https://t.me/+iXalBkHABfBkYWQ0
# Public @username (used only if TELEGRAM_CHANNEL_LINK is empty)
TELEGRAM_CHANNEL_USERNAME=wforexvip

# ==========================
# المستخدم المالك (للإدارة)
# ==========================
OWNER_EMAIL=ahmadkhldi000@gmail.com
OWNER_NAME=Ahmad Khaldi

# ==========================
# الجلسات (Session Secret)
# ==========================
# أي نص عشوائي طويل — إذا ترك فارغاً سيُنشأ تلقائياً
SESSION_SECRET=

# ==========================
# Google OAuth (optional)
# ==========================
# Get credentials: https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (Web application)
# Authorized redirect URI (local):   http://localhost:3000/api/auth/google/callback
# Authorized redirect URI (Render):  https://w-forex-dashboard.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match the URI registered in Google Console (include /api/auth/google/callback)
GOOGLE_REDIRECT_URI=

# ==========================
# إعدادات النشر (Render)
# ==========================
# عند النشر على Render، هذه المتغيرات ستُستبدل
# بالقيم المحددة في Render Dashboard